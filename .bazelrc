# Bzlmod is the default in Bazel 7; kept explicit for clarity.
common --enable_bzlmod

# Prevent Go 1.21+ toolchain version negotiation inside the Bazel sandbox.
# Without this, Go may try to download a different toolchain and fail.
build --action_env=GOTOOLCHAIN=local

# Workspace stamping injects git version info into binaries.
# Used automatically when --config=release is passed.
build:release --stamp
build:release --workspace_status_command=tools/workspace_status.sh

# Run tests with the race detector, matching 'go test -race'.
test --@rules_go//go/config:race

# Print full output for failing tests rather than just the summary.
test --test_output=errors
