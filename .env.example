# ─────────────────────────────────────────────────────────────────────────────
# nomad-botherer — local development environment
#
# Copy this file to .env and fill in your values.
# .env is loaded automatically at startup and is listed in .gitignore.
#
# All of these can also be passed as CLI flags (see --help).
# ─────────────────────────────────────────────────────────────────────────────


# ── Git ───────────────────────────────────────────────────────────────────────

# Remote git repo containing Nomad job HCL files (required).
GIT_REPO_URL=https://github.com/myorg/nomad-jobs.git

# Branch to watch for changes.
#GIT_BRANCH=main

# How often to poll the remote for new commits.
# Accepts Go duration strings: 30s, 5m, 1h, etc.
#POLL_INTERVAL=5m

# Subdirectory within the repo containing .hcl job files.
# Leave unset to scan the entire repo root.
#HCL_DIR=jobs


# ── Git authentication ────────────────────────────────────────────────────────
# Set one of GIT_TOKEN (HTTP) or GIT_SSH_KEY (SSH). Leave both unset for
# public repos or when SSH agent forwarding is in use.

# Personal access token (GitHub PAT, GitLab token, etc.).
#GIT_TOKEN=ghp_...

# Absolute path to an SSH private key.
#GIT_SSH_KEY=/home/user/.ssh/id_ed25519

# Passphrase for the SSH key (omit if the key has no passphrase).
#GIT_SSH_KEY_PASSWORD=


# ── Nomad ─────────────────────────────────────────────────────────────────────

# Nomad API address.
#NOMAD_ADDR=http://127.0.0.1:4646

# Nomad ACL token (leave unset if ACLs are disabled).
#NOMAD_TOKEN=

# Nomad namespace to inspect.
#NOMAD_NAMESPACE=default


# ── HTTP server ───────────────────────────────────────────────────────────────

# Address to listen on for /healthz, /metrics, and /webhook.
#LISTEN_ADDR=:8080

# HMAC secret used to verify incoming GitHub webhook payloads.
# Must match the secret set in the GitHub repo webhook settings.
# Leave unset to skip signature verification (not recommended in production).
#WEBHOOK_SECRET=

# HTTP path for the webhook endpoint.
#WEBHOOK_PATH=/webhook


# ── gRPC server ───────────────────────────────────────────────────────────────

# Address for the gRPC API (nbctl and grpcurl connect here).
# Set to an empty string to disable gRPC entirely.
#GRPC_LISTEN_ADDR=:9090

# Pre-shared API key for gRPC authentication.
# Required when GRPC_LISTEN_ADDR is non-empty. Use a long random string,
# e.g.: openssl rand -hex 32
#GRPC_API_KEY=


# ── Diff checking ─────────────────────────────────────────────────────────────

# How often to re-check Nomad for drift, regardless of git activity.
# Catches changes made directly in Nomad between git pushes.
#DIFF_INTERVAL=1m


# ── Logging ───────────────────────────────────────────────────────────────────

# Verbosity: debug, info, warn, error.
#LOG_LEVEL=info
